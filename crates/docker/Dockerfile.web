FROM node:20-bookworm-slim AS ui

WORKDIR /src/apps

RUN corepack enable && corepack prepare pnpm@10.30.3 --activate

COPY apps/package.json ./package.json
COPY apps/pnpm-lock.yaml ./pnpm-lock.yaml
COPY apps/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY apps/next.config.ts ./next.config.ts
COPY apps/postcss.config.mjs ./postcss.config.mjs
COPY apps/tsconfig.json ./tsconfig.json
COPY apps/components.json ./components.json
COPY apps/public ./public
COPY apps/src ./src

RUN pnpm install --frozen-lockfile
RUN pnpm run build:desktop

FROM rust:1-bookworm AS builder

WORKDIR /src

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

COPY --from=ui /src/apps/out ./apps/out

RUN cargo build -p codexmanager-web --release --features embedded-ui

FROM debian:bookworm-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/codexmanager-web /usr/local/bin/codexmanager-web

ENV CODEXMANAGER_WEB_ADDR=0.0.0.0:48761
ENV CODEXMANAGER_WEB_NO_SPAWN_SERVICE=1
ENV CODEXMANAGER_WEB_NO_OPEN=1
ENV CODEXMANAGER_SERVICE_ADDR=codexmanager-service:48760
ENV CODEXMANAGER_DB_PATH=/data/codexmanager.db
ENV CODEXMANAGER_RPC_TOKEN_FILE=/data/codexmanager.rpc-token

VOLUME ["/data"]
EXPOSE 48761

CMD ["codexmanager-web"]
